--// Rayfield UI + Auto Egg Open

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Egg Opener",
    LoadingTitle = "Egg Opener",
    LoadingSubtitle = "by ChatGPT",
    ConfigurationSaving = {
        Enabled = false
    },
    Discord = {
        Enabled = false
    },
    KeySystem = false
})

local Tab = Window:CreateTab("Main", 4483362458)
local MachinesTab = Window:CreateTab("Machines", 4483362458)

--// Config
local SelectedEgg = "Tech Egg"
local TripleEgg = true
local AutoOpen = false

--// Machines Config
local Machines = {
    Bank = false,
    DarkMatter = false,
    Golden = false,
    Rainbow = false,
    Ghost = false
}

--// Remote
local Remote = workspace
    :WaitForChild("HUH WAIT WHY ROBLOX")
    :WaitForChild("__REMOTES")
    :WaitForChild("buyx egg")

--// Dropdown
Tab:CreateDropdown({
    Name = "Egg Mode",
    Options = {"One Egg", "Triple Egg"},
    CurrentOption = {"Triple Egg"},
    Flag = "EggMode",
    Callback = function(Options)
        local Option = Options[1]

        if Option == "Triple Egg" then
            TripleEgg = true
        else
            TripleEgg = false
        end
    end,
})

--// Textbox
Tab:CreateInput({
    Name = "Egg Name",
    PlaceholderText = "Ex: Bolt Egg",
    Text = "Tech Egg",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        if Text and Text ~= "" then
            SelectedEgg = Text
        end
    end,
})

--// Toggle
Tab:CreateToggle({
    Name = "Auto Open Egg",
    CurrentValue = false,
    Flag = "AutoEgg",
    Callback = function(Value)
        AutoOpen = Value
    end,
})

--// Machines Tab - Bank Toggle
MachinesTab:CreateToggle({
    Name = "Bank",
    CurrentValue = false,
    Flag = "BankToggle",
    Callback = function(Value)
        Machines.Bank = Value
        local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        local Bank = PlayerGui:FindFirstChild("Bank")
        
        if Bank then
            Bank.Enabled = Value
        end
    end,
})

--// Machines Tab - DarkMatter Toggle
MachinesTab:CreateToggle({
    Name = "DarkMatter",
    CurrentValue = false,
    Flag = "DarkMatterToggle",
    Callback = function(Value)
        Machines.DarkMatter = Value
        local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        local DarkMatter = PlayerGui:FindFirstChild("DarkMatter")
        
        if DarkMatter then
            DarkMatter.Enabled = Value
        end
    end,
})

--// Machines Tab - Golden Toggle
MachinesTab:CreateToggle({
    Name = "Golden",
    CurrentValue = false,
    Flag = "GoldenToggle",
    Callback = function(Value)
        Machines.Golden = Value
        local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        local Golden = PlayerGui:FindFirstChild("Golden")
        
        if Golden then
            Golden.Enabled = Value
        end
    end,
})

--// Machines Tab - Rainbow Toggle
MachinesTab:CreateToggle({
    Name = "Rainbow",
    CurrentValue = false,
    Flag = "RainbowToggle",
    Callback = function(Value)
        Machines.Rainbow = Value
        local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        local Rainbow = PlayerGui:FindFirstChild("Rainbow")
        
        if Rainbow then
            Rainbow.Enabled = Value
        end
    end,
})

--// Machines Tab - Ghost Toggle
MachinesTab:CreateToggle({
    Name = "Ghost",
    CurrentValue = false,
    Flag = "GhostToggle",
    Callback = function(Value)
        Machines.Ghost = Value
        local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        local Ghost = PlayerGui:FindFirstChild("Ghost")
        
        if Ghost then
            Ghost.Enabled = Value
        end
    end,
})

--// Loop
task.spawn(function()
    while true do
        task.wait(0.01)

        if AutoOpen then
            local args = {
                {
                    SelectedEgg,
                    TripleEgg,
                    false
                }
            }

            pcall(function()
                Remote:InvokeServer(unpack(args))
            end)
        end
    end
end)
